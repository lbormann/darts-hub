<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="darts_hub.UI.AppSettingsView">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" MaxWidth="550" HorizontalAlignment="Left" Margin="20">

            <!-- Header -->
            <TextBlock Text="Application Settings"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock Text="Configure general application behavior, update preferences, and UI options."
                       TextWrapping="Wrap"
                       Foreground="#FFCCCCCC"
                       FontSize="14"/>

            <!-- Update Settings -->
            <Border Background="#33FFFFFF" CornerRadius="8" Padding="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="Updates"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <CheckBox x:Name="SkipUpdateConfirmationCheckBox"
                              Content="Skip update confirmation"
                              Foreground="White"
                              FontSize="13"/>

                    <TextBlock Text="When enabled, updates will be installed automatically without asking for confirmation."
                               TextWrapping="Wrap"
                               Foreground="#FF999999"
                               FontSize="12"
                               Margin="28,0,0,0"/>

                    <CheckBox x:Name="BetaTesterCheckBox"
                              Content="Enable beta updates"
                              Foreground="White"
                              FontSize="13"/>

                    <TextBlock Text="Receive pre-release versions that may contain new features but could be less stable."
                               TextWrapping="Wrap"
                               Foreground="#FF999999"
                               FontSize="12"
                               Margin="28,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- UI Settings -->
            <Border Background="#33FFFFFF" CornerRadius="8" Padding="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="User Interface"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <CheckBox x:Name="NewSettingsModeCheckBox"
                              Content="Enable enhanced settings mode (Beta)"
                              Foreground="White"
                              FontSize="13"/>

                    <TextBlock Text="Uses an improved layout for app configuration pages with better organization and more details."
                               TextWrapping="Wrap"
                               Foreground="#FF999999"
                               FontSize="12"
                               Margin="28,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Startup Settings -->
            <Border Background="#33FFFFFF" CornerRadius="8" Padding="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="Startup"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Splash screen countdown (seconds)"
                                   Foreground="White"
                                   FontSize="13"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <NumericUpDown x:Name="SplashCountdownNumeric"
                                           Minimum="0"
                                           Maximum="300"
                                           Increment="1"
                                           Width="120"
                                           FontSize="13"
                                           FormatString="0"/>
                        </StackPanel>
                        <TextBlock Text="Duration of the countdown splash screen shown before the application starts (0-300s / max 5 min). Set to 0 to disable."
                                   TextWrapping="Wrap"
                                   Foreground="#FF999999"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Monitor Settings -->
            <Border Background="#33FFFFFF" CornerRadius="8" Padding="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="Display"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <CheckBox x:Name="UseSpecificMonitorCheckBox"
                              Content="Always start on a specific monitor"
                              Foreground="White"
                              FontSize="13"/>

                    <TextBlock Text="When enabled, the application window will always open on the selected monitor."
                               TextWrapping="Wrap"
                               Foreground="#FF999999"
                               FontSize="12"
                               Margin="28,0,0,0"/>

                    <StackPanel x:Name="MonitorSelectionPanel" Spacing="8" IsVisible="False" Margin="28,0,0,0">
                        <TextBlock Text="Select monitor"
                                   Foreground="White"
                                   FontSize="13"/>
                        <ComboBox x:Name="MonitorComboBox"
                                  HorizontalAlignment="Stretch"
                                  MaxWidth="400"
                                  FontSize="13"/>
                        <Button x:Name="MoveToMonitorButton"
                                Content="Move window to selected monitor"
                                Padding="12,6"
                                Background="#FF007ACC"
                                BorderBrush="#FF005A9E"
                                BorderThickness="1"
                                CornerRadius="4"
                                Foreground="White"
                                FontSize="13"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- WLED Start Actions -->
            <Border Background="#33FFFFFF" CornerRadius="8" Padding="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="WLED Start Actions"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <TextBlock Text="Control external WLED devices when Darts-Hub starts. You can turn devices on or activate a specific preset."
                               TextWrapping="Wrap"
                               Foreground="#FF999999"
                               FontSize="12"/>

                    <!-- Lock overlay (shown when license feature is missing) -->
                    <Border x:Name="WledStartLockedPanel" IsVisible="False"/>

                    <!-- Content (shown when licensed) -->
                    <StackPanel x:Name="WledStartContentPanel" Spacing="10">
                        <StackPanel x:Name="WledStartDeviceListPanel" Spacing="10"/>

                        <Button x:Name="WledStartAddDeviceButton"
                                Content="+ Add WLED device"
                                Padding="12,6"
                                Background="#FF28A745"
                                BorderBrush="#FF1E7E34"
                                BorderThickness="1"
                                CornerRadius="4"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- WLED Close Actions -->
            <Border Background="#33FFFFFF" CornerRadius="8" Padding="15">
                <StackPanel Spacing="12">
                    <TextBlock Text="WLED Close Actions"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <TextBlock Text="Control external WLED devices when Darts-Hub is closed. You can turn devices off or activate a specific preset."
                               TextWrapping="Wrap"
                               Foreground="#FF999999"
                               FontSize="12"/>

                    <!-- Lock overlay (shown when license feature is missing) -->
                    <Border x:Name="WledCloseLockedPanel" IsVisible="False"/>

                    <!-- Content (shown when licensed) -->
                    <StackPanel x:Name="WledCloseContentPanel" Spacing="10">
                        <StackPanel x:Name="WledDeviceListPanel" Spacing="10"/>

                        <Button x:Name="WledAddDeviceButton"
                                Content="+ Add WLED device"
                                Padding="12,6"
                                Background="#FF28A745"
                                BorderBrush="#FF1E7E34"
                                BorderThickness="1"
                                CornerRadius="4"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- App Information -->
            <Border Background="#33FFFFFF" CornerRadius="8" Padding="15">
                <StackPanel Spacing="8">
                    <TextBlock Text="Information"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Version:"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                        <TextBlock x:Name="AppVersionText"
                                   Text="v0.0.0"
                                   Foreground="#FFCCCCCC"
                                   FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
