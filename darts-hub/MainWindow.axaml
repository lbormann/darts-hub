<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="darts_hub.MainWindow"
        Title="Darts-Hub"
		Icon="/Assets/favicon.ico"
		Width="1000"
		Height="800"
		MinWidth="700"
		MinHeight="400"
		WindowStartupLocation="CenterScreen"
		CanResize="True">
	<Window.Background>
		<ImageBrush Source="/Assets/darthub_bg.png"
                   Stretch="UniformToFill"
                   Opacity="1.0"
                   AlignmentX="Center"
                   AlignmentY="Center"/>
	</Window.Background>

	<!-- Root layout: main content + status bar + overlays -->
	<Grid x:Name="RootGrid">
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Main content grid (fills all available space) -->
		<Grid x:Name="MainGrid" Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="250" MinWidth="180"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="*" MinWidth="300"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="250" MinWidth="150"/>
			</Grid.ColumnDefinitions>

			<!-- Navigation Panel -->
			<Border Grid.Column="0" Background="#F22D2D30" BorderBrush="#FF464647" BorderThickness="0,0,1,0">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<!-- Menu and Start Buttons -->
					<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="10,8,10,4">
						<Button x:Name="ButtonSidebarMenu"
								Padding="10,7"
								Background="#FF333337"
								BorderBrush="#FF555558"
								BorderThickness="1"
								CornerRadius="5"
								Foreground="White"
								FontSize="16"
								Click="ButtonSidebarMenu_Click"
								ToolTip.Tip="Open menu">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<Border Width="18" Height="14" VerticalAlignment="Center">
									<StackPanel Spacing="3" VerticalAlignment="Center">
										<Border Height="2" Background="White" CornerRadius="1"/>
										<Border Height="2" Background="White" CornerRadius="1"/>
										<Border Height="2" Background="White" CornerRadius="1"/>
									</StackPanel>
								</Border>
							</StackPanel>
						</Button>
						<Button x:Name="Buttonstart"
								Padding="10,7"
								Background="#FF2D7D2D"
								BorderBrush="#FF3A9A3A"
								BorderThickness="1"
								CornerRadius="5"
								Foreground="White"
								Click="Buttonstart_Click"
								ToolTip.Tip="Start selected profile">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<Image x:Name="darts_png" Width="18" Height="18" Source="/Assets/darts.png" VerticalAlignment="Center"/>
								<TextBlock Text="Start" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
					</StackPanel>

					<!-- App Navigation -->
					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
						<StackPanel x:Name="AppNavigationPanel" Margin="5"/>
					</ScrollViewer>

				</Grid>
			</Border>

			<!-- Splitter 1 -->
			<GridSplitter Grid.Column="1" Background="#FF464647" HorizontalAlignment="Stretch"/>

			<!-- Settings/Content Panel -->
			<Border Grid.Column="2" Background="#F2252526" BorderBrush="#FF464647" BorderThickness="0,0,1,0">
				<Grid>
					<!-- Settings Content -->
					<ScrollViewer x:Name="SettingsScrollViewer" 
								  VerticalScrollBarVisibility="Auto" 
								  HorizontalScrollBarVisibility="Auto"
								  Background="Transparent"
								  Padding="0,0">
						<StackPanel x:Name="SettingsPanel">
							<TextBlock Text="Select an app from the navigation panel to configure its settings" 
									   Foreground="#FF999999" 
									   FontSize="16" 
									   HorizontalAlignment="Center" 
									   VerticalAlignment="Center" 
									   Margin="20"/>
						</StackPanel>
					</ScrollViewer>

					<!-- About Content -->
					<ScrollViewer x:Name="AboutScrollViewer" 
								  VerticalScrollBarVisibility="Auto" 
								  HorizontalScrollBarVisibility="Disabled"
								  Padding="0"
								  IsVisible="False">
						<StackPanel x:Name="AboutPanel" HorizontalAlignment="Center" MaxWidth="520" Margin="24,20,24,30" Spacing="20">

							<!-- Hero Section -->
							<Border Background="#28FFFFFF" CornerRadius="14" Padding="28,24" BorderBrush="#30FFFFFF" BorderThickness="1">
								<StackPanel Spacing="10" HorizontalAlignment="Center">
									<Image Source="/Assets/darts.png" Width="56" Height="56" HorizontalAlignment="Center"/>
									<TextBlock Text="Darts-Hub"
											   FontSize="26"
											   FontWeight="Bold"
											   Foreground="White"
											   HorizontalAlignment="Center"/>
									<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
										<TextBlock Text="Version" FontSize="13" Foreground="#FFAAAAAA" VerticalAlignment="Center"/>
										<Label x:Name="AboutAppVersion" Content="v0.0.0" FontSize="13" Foreground="#FF8CB4FF" Padding="0" VerticalAlignment="Center"/>
									</StackPanel>
									<TextBlock TextWrapping="Wrap"
											   Text="Manage your AutoDarts extensions like Darts-WLED or Darts-Caller &#x2014; or launch your own executables automatically."
											   FontSize="13"
											   Foreground="#FFBBBBBB"
											   HorizontalAlignment="Center"
											   TextAlignment="Center"
											   Margin="0,4,0,0"/>
								</StackPanel>
							</Border>

							<!-- Robbel3D Quick Setup (hidden by default) -->
							<Button x:Name="Robbel3DConfigButton"
									Padding="14,10"
									Background="#FF28A745"
									BorderBrush="#FF1E7E34"
									BorderThickness="1"
									CornerRadius="8"
									Foreground="White"
									FontWeight="Bold"
									FontSize="14"
									HorizontalAlignment="Stretch"
									HorizontalContentAlignment="Center"
									Click="Robbel3DConfigButton_Click"
									ToolTip.Tip="Configure WLED and Caller with optimized Robbel3D presets"
									IsVisible="False">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<TextBlock Text="&#x1F680;" FontSize="16" VerticalAlignment="Center"/>
									<TextBlock Text="Robbel3D One-Click Setup" VerticalAlignment="Center"/>
								</StackPanel>
							</Button>

							<!-- Support &amp; Community Card -->
								<Border Background="#300078D4" CornerRadius="12" Padding="22,20" BorderBrush="#500078D4" BorderThickness="1.5">
									<StackPanel Spacing="14">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="&#x2764;" FontSize="16" VerticalAlignment="Center"/>
											<TextBlock Text="Support &amp; Community"
													   FontSize="16"
													   FontWeight="Bold"
													   Foreground="White"/>
										</StackPanel>
										<TextBlock Text="Your support keeps this project alive!"
												   FontSize="12"
												   Foreground="#FF99BBE8"
												   Margin="0,-6,0,2"/>

										<!-- Donate Row -->
										<Border Background="#22FFFFFF" CornerRadius="8" Padding="14,10">
											<DockPanel>
												<StackPanel VerticalAlignment="Center">
													<TextBlock Text="Donate"
															   FontSize="13"
															   FontWeight="SemiBold"
															   Foreground="White"/>
													<TextBlock Text="Support development with a tip"
															   FontSize="11"
															   Foreground="#FFAAAAAA"
															   TextWrapping="Wrap"/>
												</StackPanel>
												<StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Spacing="4" VerticalAlignment="Center" Margin="10,0,0,0">
													<Button ToolTip.Tip="Support the project via PayPal"
															x:Name="AboutPaypal"
															Background="Transparent"
															BorderThickness="0"
															Click="AboutButton_Click"
															Cursor="Hand"
															Padding="4">
														<Image Width="34" Height="34" Source="/Assets/paypal.png"/>
													</Button>
													<Button ToolTip.Tip="Buy us a coffee on Ko-fi"
															x:Name="AboutKofi"
															Background="Transparent"
															BorderThickness="0"
															Click="AboutButton_Click"
															Cursor="Hand"
															Padding="4">
														<Image Width="34" Height="34" Source="/Assets/kofi.png"/>
													</Button>
													<Button ToolTip.Tip="Appreciate our work? Send some satoshi"
															x:Name="AboutDonation"
															Background="Transparent"
															BorderThickness="0"
															Click="AboutButton_Click"
															Cursor="Hand"
															Padding="4">
														<Image Width="34" Height="34" Source="/Assets/donation.png"/>
													</Button>
												</StackPanel>
											</DockPanel>
										</Border>

										<!-- Discord Row -->
										<Border Background="#22FFFFFF" CornerRadius="8" Padding="14,10">
											<DockPanel>
												<StackPanel VerticalAlignment="Center">
													<TextBlock Text="Discord"
															   FontSize="13"
															   FontWeight="SemiBold"
															   Foreground="White"/>
													<TextBlock Text="Join the community server"
															   FontSize="11"
															   Foreground="#FFAAAAAA"
															   TextWrapping="Wrap"/>
												</StackPanel>
												<Button ToolTip.Tip="Join the official Discord server"
														x:Name="AboutDiscord"
														Background="Transparent"
														BorderThickness="0"
														Click="AboutButton_Click"
														Cursor="Hand"
														DockPanel.Dock="Right"
														Padding="4"
														Margin="10,0,0,0">
													<Image Width="34" Height="34" Source="/Assets/discord.png"/>
												</Button>
											</DockPanel>
										</Border>

										<!-- Bug Report Row -->
										<Border Background="#22FFFFFF" CornerRadius="8" Padding="14,10">
											<DockPanel>
												<StackPanel VerticalAlignment="Center">
													<TextBlock Text="Report a Bug"
															   FontSize="13"
															   FontWeight="SemiBold"
															   Foreground="White"/>
													<TextBlock Text="Create an issue on GitHub"
															   FontSize="11"
															   Foreground="#FFAAAAAA"
															   TextWrapping="Wrap"/>
												</StackPanel>
												<Button ToolTip.Tip="Found a bug? Create an issue on GitHub"
														x:Name="AboutBug"
														Background="Transparent"
														BorderThickness="0"
														Click="AboutButton_Click"
														Cursor="Hand"
														DockPanel.Dock="Right"
														Padding="4"
														Margin="10,0,0,0">
													<Image Width="28" Height="28" Source="/Assets/bug.png"/>
												</Button>
											</DockPanel>
										</Border>
									</StackPanel>
								</Border>

							<!-- Developers Card -->
							<Border Background="#20FFFFFF" CornerRadius="12" Padding="20,18" BorderBrush="#18FFFFFF" BorderThickness="1">
								<StackPanel Spacing="14">
									<TextBlock Text="Developers"
											   FontSize="15"
											   FontWeight="SemiBold"
											   Foreground="#FFE0E0E0"/>

									<!-- I3uLL3t -->
									<Border Background="#18FFFFFF" CornerRadius="10" Padding="14,12">
										<DockPanel>
											<Border Width="44" Height="44"
													CornerRadius="22"
													DockPanel.Dock="Left"
													Margin="0,0,12,0"
													ClipToBounds="True">
												<Image Source="/Assets/I3uLL3t.png"
													   Width="44" Height="44"
													   Stretch="UniformToFill"/>
											</Border>
											<Button ToolTip.Tip="Contact the Dev"
													x:Name="AboutContact3"
													Background="Transparent"
													BorderThickness="0"
													Click="AboutButton_Click"
													DockPanel.Dock="Right"
													Cursor="Hand"
													Padding="4"
													VerticalAlignment="Center"
													Margin="8,0,0,0">
												<Image Width="22" Height="22" Source="/Assets/contact.png"/>
											</Button>
											<StackPanel VerticalAlignment="Center" Spacing="2">
												<StackPanel Orientation="Horizontal" Spacing="8">
													<TextBlock Text="I3uLL3t" FontWeight="Bold" FontSize="14" Foreground="White"/>
													<Border Background="#2013fa02" CornerRadius="4" Padding="6,2">
														<TextBlock Text="Active" FontSize="11" Foreground="#13fa02"/>
													</Border>
												</StackPanel>
												<TextBlock Text="GitHub: Peschi90"
														   FontSize="12"
														   Foreground="#FF8CB4FF"
														   TextDecorations="Underline"
														   Cursor="Hand"/>
											</StackPanel>
										</DockPanel>
									</Border>

									<!-- Wusaaa -->
									<Border Background="#18FFFFFF" CornerRadius="10" Padding="14,12">
										<DockPanel>
											<Border Width="44" Height="44"
													CornerRadius="22"
													DockPanel.Dock="Left"
													Margin="0,0,12,0"
													ClipToBounds="True">
												<Image Source="/Assets/wusaaa.jpeg"
													   Width="44" Height="44"
													   Stretch="UniformToFill"/>
											</Border>
											<Button ToolTip.Tip="Contact the Dev"
													x:Name="AboutContact2"
													Background="Transparent"
													BorderThickness="0"
													Click="AboutButton_Click"
													DockPanel.Dock="Right"
													Cursor="Hand"
													Padding="4"
													VerticalAlignment="Center"
													Margin="8,0,0,0">
												<Image Width="22" Height="22" Source="/Assets/contact.png"/>
											</Button>
											<StackPanel VerticalAlignment="Center" Spacing="2">
												<StackPanel Orientation="Horizontal" Spacing="8">
													<TextBlock Text="Wusaaa" FontWeight="Bold" FontSize="14" Foreground="White"/>
													<Border Background="#20FFA500" CornerRadius="4" Padding="6,2">
														<TextBlock Text="Inactive" FontSize="11" Foreground="Orange"/>
													</Border>
												</StackPanel>
												<TextBlock Text="GitHub: Ibormann"
														   FontSize="12"
														   Foreground="#FF8CB4FF"
														   TextDecorations="Underline"
														   Cursor="Hand"/>
											</StackPanel>
										</DockPanel>
									</Border>
								</StackPanel>
							</Border>

						</StackPanel>
					</ScrollViewer>

					<!-- Changelog Content -->
				<ScrollViewer x:Name="ChangelogScrollViewer" 
							  VerticalScrollBarVisibility="Auto" 
							  HorizontalScrollBarVisibility="Auto"
							  IsVisible="False">
						<ContentControl x:Name="ChangelogHost" />
					</ScrollViewer>

					<!-- To Top Button -->
					<Button x:Name="ToTopButton"
							Width="40"
							Height="40"
							HorizontalAlignment="Right"
							VerticalAlignment="Bottom"
							Margin="0,0,20,20"
							Background="#FF0078D4"
							BorderBrush="#FF005A9E"
							BorderThickness="2"
							CornerRadius="25"
							Opacity="0"
							IsVisible="False"
							Click="ToTopButton_Click"
							ZIndex="100"
							ToolTip.Tip="Scroll to top">
						<TextBlock Text="&#x2191;" 
								   FontSize="24" 
								   FontWeight="Bold"
								   Foreground="White"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Center"/>
					</Button>
				</Grid>
			</Border>

			<!-- Splitter 2 -->
			<GridSplitter Grid.Column="3" Background="#FF464647" HorizontalAlignment="Stretch" x:Name="TooltipSplitter"/>

			<!-- Tooltip Panel -->
			<Border Grid.Column="4" Background="#F21E1E22" x:Name="TooltipPanel" ClipToBounds="True">
				<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
					<Border Margin="10,12,10,12" Background="#28FFFFFF" CornerRadius="10" Padding="12,10" BorderBrush="#18FFFFFF" BorderThickness="1" ClipToBounds="True">
						<StackPanel x:Name="TooltipContent" Spacing="4">
							<DockPanel>
								<TextBlock Text="&#x1F4A1;" FontSize="14" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,8,0"/>
								<TextBlock x:Name="TooltipTitle" 
										   Text="Darts-Hub Info Area" 
										   Foreground="White" 
										   FontSize="14" 
										   FontWeight="Bold" 
										   TextWrapping="Wrap"
										   VerticalAlignment="Center"/>
							</DockPanel>
							<Border Height="1" Background="#20FFFFFF" Margin="0,6,0,4" CornerRadius="1"/>
							<TextBlock x:Name="TooltipDescription" 
									   Foreground="#FFBBBBBB"
									   TextWrapping="Wrap" 
									   FontSize="13"
									   LineHeight="20">
								<TextBlock.Text>This is your central hub for managing darts applications. Use the navigation panel to configure your apps, or click on settings to see detailed information here.</TextBlock.Text>
							</TextBlock>
						</StackPanel>
					</Border>
				</ScrollViewer>
			</Border>

			<!-- Console Content - spans across Settings and Tooltip columns -->
			<Border Grid.Column="2" Grid.ColumnSpan="3" Background="#FF1A1A1A" x:Name="ConsolePanel" IsVisible="False">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					
				<Border Grid.Row="0" Background="#FF2D2D30" Padding="10,5">
						<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="Console Output" 
										   Foreground="White" 
										   FontSize="16" 
										   FontWeight="Bold" 
										   VerticalAlignment="Center"/>
								<Button x:Name="ConsoleClearButton" 
										Content="Clear All" 
										Margin="10,0,0,0" 
										Padding="8,4"
										Background="#FF444444" 
										Foreground="White"
										BorderThickness="0"
										CornerRadius="3"
										Click="ConsoleClearButton_Click"/>
								<Button x:Name="ConsoleClearCurrentButton" 
										Content="Clear Current" 
										Margin="5,0,0,0" 
										Padding="8,4"
										Background="#FF666666" 
										Foreground="White"
										BorderThickness="0"
										CornerRadius="3"
										Click="ConsoleClearCurrentButton_Click"/>
								<Button x:Name="ConsoleExportButton" 
										Content="Export Log" 
										Margin="5,0,0,0" 
										Padding="8,4"
										Background="#FF0078D4" 
										Foreground="White"
										BorderThickness="0"
										CornerRadius="3"
										Click="ConsoleExportButton_Click"/>
								<Button x:Name="ConsoleTestUpdaterButton" 
										Content="&#x1F9EA; Test Updater" 
										Margin="10,0,0,0" 
										Padding="8,4"
										Background="#FF28A745" 
										Foreground="White"
										BorderThickness="0"
										CornerRadius="3"
										Click="ConsoleTestUpdaterButton_Click"
										ToolTip.Tip="Test the update system functionality"/>
								<CheckBox x:Name="ConsoleAutoScrollCheckBox" 
										  Content="Auto-scroll" 
										  Margin="10,0,0,0" 
										  Foreground="White"
										  IsChecked="True"
										  Checked="ConsoleAutoScrollCheckBox_Changed"
										  Unchecked="ConsoleAutoScrollCheckBox_Changed"/>
							</StackPanel>
						</ScrollViewer>
					</Border>
					
					<TabControl x:Name="ConsoleTabControl" 
								Grid.Row="1"
								Background="#FF252526"
								BorderThickness="0"
								Padding="0,0,0,15">
					</TabControl>
				</Grid>
			</Border>

			<!-- New Settings Content - spans across Settings and Tooltip columns -->
			<Border Grid.Column="2" Grid.ColumnSpan="3" Background="#FF252526" x:Name="NewSettingsPanel" IsVisible="False">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

				<Border Grid.Row="0" Background="#FF2D2D30" Padding="10,5">
							<TextBlock Text="Enhanced Settings Mode" 
									   Foreground="White" 
									   FontSize="16" 
									   FontWeight="Bold" 
									   VerticalAlignment="Center"/>
						</Border>

						<!-- Section Navigation Bar -->
							<Border Grid.Row="1" x:Name="SectionNavBar" Background="#FF1E1E1E" 
									BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1"
									MinHeight="49"
									IsVisible="False">
								<ScrollViewer HorizontalScrollBarVisibility="Auto" 
											  VerticalScrollBarVisibility="Disabled"
											  Padding="0,0,0,14">
									<StackPanel x:Name="SectionNavBarContent" 
												Orientation="Horizontal" 
												Margin="10,6,10,0" 
												Spacing="4"/>
								</ScrollViewer>
							</Border>

						<ScrollViewer Grid.Row="2" 
									  x:Name="NewSettingsScrollViewer"
									  VerticalScrollBarVisibility="Auto" 
									  HorizontalScrollBarVisibility="Disabled"
									  Background="Transparent">
								<StackPanel x:Name="NewSettingsContent">
									<TextBlock Text="Enhanced settings will appear here..." 
											   Foreground="#FF999999" 
											   FontSize="16" 
											   HorizontalAlignment="Center" 
											   VerticalAlignment="Center" 
											   Margin="20"/>
								</StackPanel>
							</ScrollViewer>
					</Grid>
				</Border>
		</Grid>

		<!-- License Status Bar -->
		<Border Grid.Row="1"
				Background="#FF1A1A1A"
				BorderBrush="#FF464647"
				BorderThickness="0,1,0,0"
				Padding="10,4">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
				<TextBlock x:Name="StatusBarLicenseIcon"
						   Text="&#x1F511;"
						   FontSize="12"
						   VerticalAlignment="Center"/>
				<TextBlock x:Name="StatusBarLicenseText"
						   Text="License: Checking..."
						   FontSize="12"
						   Foreground="#FF999999"
						   VerticalAlignment="Center"/>
			</StackPanel>
		</Border>

		<!-- Sidebar Menu Overlay (click to close) - covers entire window -->
		<Border x:Name="SidebarMenuOverlay"
				Grid.RowSpan="2"
				Background="#88000000"
				IsVisible="False"
				ZIndex="900"
				PointerPressed="SidebarMenuOverlay_PointerPressed"/>

		<!-- Sidebar Menu Panel - covers entire window height -->
		<Border x:Name="SidebarMenuPanel"
				Grid.RowSpan="2"
				Width="260"
				HorizontalAlignment="Left"
				Background="#FF1E1E1E"
				BorderBrush="#FF3A3A3C"
				BorderThickness="0,0,1,0"
				IsVisible="False"
				ZIndex="950">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Header -->
				<Border Grid.Row="0" Background="#FF2D2D30" Padding="16,12" BorderBrush="#FF3A3A3C" BorderThickness="0,0,0,1">
					<StackPanel Orientation="Horizontal" Spacing="10">
						<Image Width="20" Height="20" Source="/Assets/darts.png" VerticalAlignment="Center"/>
						<TextBlock Text="Darts-Hub" FontSize="17" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
					</StackPanel>
				</Border>

				<!-- Menu Items -->
				<StackPanel Grid.Row="1" Margin="0,6,0,0">
					<Button x:Name="SidebarAboutButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarAboutButton_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Image Width="18" Height="18" Source="/Assets/about.png" VerticalAlignment="Center"/>
							<TextBlock Text="About" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button x:Name="SidebarConsoleButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarConsoleButton_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Image Width="18" Height="18" Source="/Assets/terminal.png" VerticalAlignment="Center"/>
							<TextBlock Text="Console" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button x:Name="SidebarChangelogButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarChangelogButton_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Image Width="18" Height="18" Source="/Assets/changelog.png" VerticalAlignment="Center"/>
							<TextBlock Text="Changelog" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Border Height="1" Background="#FF3A3A3C" Margin="12,6"/>
					<Button x:Name="SidebarAppSettingsButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarAppSettingsButton_Click"
							ToolTip.Tip="Configure application-wide settings">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Image Width="18" Height="18" Source="/Assets/configuration.png" VerticalAlignment="Center"/>
							<TextBlock Text="Settings" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button x:Name="SidebarSetupWizardButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarSetupWizardButton_Click"
							ToolTip.Tip="Re-run the initial setup wizard to configure your applications">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Image Width="18" Height="18" Source="/Assets/darts.png" VerticalAlignment="Center"/>
							<TextBlock Text="Setup Wizard" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Border Height="1" Background="#FF3A3A3C" Margin="12,6"/>
					<Button x:Name="SidebarSettingsButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarSettingsButton_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
								<Image Width="18" Height="18" Source="/Assets/configuration.png" VerticalAlignment="Center"/>
								<TextBlock Text="License Settings" FontSize="14" VerticalAlignment="Center"/>
							</StackPanel>
					</Button>
					<Border Height="1" Background="#FF3A3A3C" Margin="12,6"/>
					<Button x:Name="SidebarRollbackButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarRollbackButton_Click"
							ToolTip.Tip="Roll back to a previous version of Darts-Hub">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<TextBlock Text="&#x21A9;" FontSize="18" VerticalAlignment="Center"/>
							<TextBlock Text="Version Rollback" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Border Height="1" Background="#FF3A3A3C" Margin="12,6"/>
					<Button x:Name="SidebarDebugCollectionButton"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Background="Transparent"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="4"
							Padding="16,10"
							Margin="6,2"
							FontSize="14"
							Click="SidebarDebugCollectionButton_Click"
							ToolTip.Tip="Bundle log files and configuration into a ZIP for support">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<TextBlock Text="&#x1F41E;" FontSize="18" VerticalAlignment="Center"/>
							<TextBlock Text="Debug Collection" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<!-- Profile Controls (bottom) -->
				<Border Grid.Row="2" BorderBrush="#FF3A3A3C" BorderThickness="0,1,0,0" Padding="14,10">
					<StackPanel Spacing="8">
						<Label x:Name="SelectProfile" Content="Select profile:" Foreground="#FFCCCCCC" FontSize="12"/>
						<ComboBox x:Name="Comboboxportal" 
								  HorizontalAlignment="Stretch" 
								  SelectionChanged="Comboboxportal_SelectionChanged" 
								  SelectedIndex="0"/>
						<CheckBox x:Name="CheckBoxStartProfileOnProgramStart" 
								  Content="Start with App" 
								  Foreground="White" 
								  FontSize="12"
								  Checked="CheckBoxStartProfileOnProgramStartChanged" 
								  Unchecked="CheckBoxStartProfileOnProgramStartChanged"/>

					</StackPanel>
				</Border>
			</Grid>
		</Border>

		<!-- Loading Overlay - covers entire window -->
		<Border x:Name="LoadingOverlay" 
				Grid.RowSpan="2"
				Background="#AA000000" 
				IsVisible="False"
				ZIndex="1000">
			<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
				<Border Width="60"
						Height="60"
						CornerRadius="30"
						BorderBrush="White"
						BorderThickness="4"
						Margin="0,0,0,20">
					<Ellipse Width="40" Height="40" 
							 Fill="Transparent" 
							 Stroke="White" 
							 StrokeThickness="3" 
							 StrokeDashArray="5,3"/>
				</Border>
				<TextBlock x:Name="WaitingText"
						   Text="Please wait..."
						   TextAlignment="Center"
						   Foreground="White"
						   FontSize="20"
						   FontWeight="Bold"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>
